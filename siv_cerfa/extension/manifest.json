{
  "manifest_version": 3,
  "name": "SIV → CERFA | Dreux Carte Grise",
  "version": "2.0.0",
  "description": "Génère automatiquement les CERFA 13750 et 13757 depuis l'écran de validation SIV Pro.",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://pro-siv.interieur.gouv.fr/*",
    "http://localhost:5000/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SIV → CERFA"
  },

  "content_scripts": [
    {
      "matches": [
        "https://pro-siv.interieur.gouv.fr/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
